#!/usr/bin/env bash
# updateaidevkit - Update AI Dev Kit, refresh skills in all ~/dev/ projects,
#                  and regenerate ~/.claude/CLAUDE.md skill table from source
set -euo pipefail

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log()  { echo -e "${CYAN}▶${RESET} $*"; }
ok()   { echo -e "${GREEN}✓${RESET} $*"; }
warn() { echo -e "${YELLOW}⚠${RESET}  $*"; }
die()  { echo -e "${RED}✗${RESET} $*" >&2; exit 1; }

CONFIG_FILE="$HOME/.config/aidevkit/config"
if [[ -f "$CONFIG_FILE" ]]; then
  source "$CONFIG_FILE"
fi
DEV_DIR="${DEV_DIR:-$HOME/dev}"
AI_DEV_KIT_REPO="$HOME/.ai-dev-kit/repo"
AI_DEV_KIT_VERSION_FILE="$HOME/.ai-dev-kit/version"
GLOBAL_CLAUDE_MD="$HOME/.claude/CLAUDE.md"

echo ""
echo -e "${BOLD}updateaidevkit${RESET} — keeping your AI Dev Kit in sync"
echo "──────────────────────────────────────────────────"

# ── Step 1: Re-run AI Dev Kit installer with --force ─────────────────────────
echo ""
log "Updating AI Dev Kit core (MCP server, venv, dependencies)..."
echo -e "  ${YELLOW}(Running installer with --force from a temp directory)${RESET}"
echo ""

TMPDIR_UPDATE="$(mktemp -d)"
trap 'rm -rf "$TMPDIR_UPDATE"' EXIT

(
  cd "$TMPDIR_UPDATE"
  DEVKIT_PROFILE=DEFAULT \
  DEVKIT_SCOPE=project \
  DEVKIT_TOOLS=claude,cursor,copilot \
  DEVKIT_MCP_PATH="$HOME/.ai-dev-kit" \
  DEVKIT_FORCE=true \
  DEVKIT_SILENT=true \
    bash <(curl -sL https://raw.githubusercontent.com/databricks-solutions/ai-dev-kit/main/install.sh)
) || warn "AI Dev Kit core update had warnings — continuing anyway."

INSTALLED_VERSION="$(cat "$AI_DEV_KIT_VERSION_FILE" 2>/dev/null || echo 'unknown')"
ok "AI Dev Kit updated to v${INSTALLED_VERSION}"

# ── Pull latest main into local repo clone so it stays current ───────────────
if [[ -d "$AI_DEV_KIT_REPO/.git" ]]; then
  log "Pulling latest main into ~/.ai-dev-kit/repo..."
  git -C "$AI_DEV_KIT_REPO" fetch origin main 2>/dev/null && \
  git -C "$AI_DEV_KIT_REPO" checkout FETCH_HEAD 2>/dev/null && \
  ok "Local repo updated to latest main" || \
  warn "Could not pull main — local repo may be behind"
fi

# ── Step 2: Refresh skills in all dev projects that have .ai-dev-kit ──────────
echo ""
log "Refreshing skills in all projects in ~/dev/ (including customer folders)..."

UPDATED=0
FIRST_PROJECT_SKILLS_DIR=""

# Find projects at depth 1 (~/dev/project/) AND depth 2 (~/dev/customer/project/)
# A project is identified by having .ai-dev-kit directory
find "$DEV_DIR" -maxdepth 3 -name ".ai-dev-kit" -type d 2>/dev/null | sort | while read aidevkit_dir; do
  project_dir="$(dirname "$aidevkit_dir")"
  # Skip if the directory IS a customer folder (has CUSTOMER.md but no .ai-dev-kit at root)
  [[ -f "$project_dir/CUSTOMER.md" ]] && continue

  # Build display name: "customer/project" for nested, "project" for flat
  relative_path="${project_dir#$DEV_DIR/}"
  project_name="$relative_path"

  echo -e "  ${CYAN}→${RESET} $project_name"

  # Preserve custom skills before overwriting managed skills
  local_custom_dir="$project_dir/.claude/skills/custom"
  custom_backup=""
  if [[ -d "$local_custom_dir" ]]; then
    custom_backup="$(mktemp -d)"
    cp -R "$local_custom_dir" "$custom_backup/custom"
    echo -e "    ${YELLOW}↳ Preserved custom skills${RESET}"
  fi

  (
    cd "$project_dir"
    bash <(curl -sL https://raw.githubusercontent.com/databricks-solutions/ai-dev-kit/main/databricks-skills/install_skills.sh) --force \
      2>&1 | grep -E "✓|✗|Installed|Skipped|Error" | sed 's/^/    /' || true
  )

  # Restore custom skills after managed skills are refreshed
  if [[ -n "$custom_backup" && -d "$custom_backup/custom" ]]; then
    mkdir -p "$local_custom_dir"
    cp -R "$custom_backup/custom/"* "$local_custom_dir/" 2>/dev/null || true
    rm -rf "$custom_backup"
    echo -e "    ${GREEN}↳ Restored custom skills${RESET}"
  fi

  # Refresh customer context if project has markers
  PROJECT_CLAUDE_MD=""
  [[ -f "$project_dir/.claude/CLAUDE.md" ]] && PROJECT_CLAUDE_MD="$project_dir/.claude/CLAUDE.md"
  [[ -z "$PROJECT_CLAUDE_MD" && -f "$project_dir/CLAUDE.md" ]] && PROJECT_CLAUDE_MD="$project_dir/CLAUDE.md"

  if [[ -n "$PROJECT_CLAUDE_MD" ]] && grep -q "CUSTOMER_CONTEXT_START:" "$PROJECT_CLAUDE_MD" 2>/dev/null; then
    cust_name=$(grep "CUSTOMER_CONTEXT_START:" "$PROJECT_CLAUDE_MD" | head -1 | sed 's/.*START://' | sed 's/ *-->.*//')
    cust_file="$(dirname "$project_dir")/CUSTOMER.md"
    if [[ -f "$cust_file" ]]; then
      # Replace content between markers with fresh CUSTOMER.md
      # Use python for reliable multi-line replacement
      python3 -c "
import re
with open('$PROJECT_CLAUDE_MD') as f:
    content = f.read()
pattern = r'<!-- CUSTOMER_CONTEXT_START:.*?-->.*?<!-- CUSTOMER_CONTEXT_END -->'
with open('$cust_file') as f:
    customer_content = f.read()
replacement = '<!-- CUSTOMER_CONTEXT_START:${cust_name} -->\n\n' + customer_content + '\n\n<!-- CUSTOMER_CONTEXT_END -->'
new_content = re.sub(pattern, replacement, content, flags=re.DOTALL)
with open('$PROJECT_CLAUDE_MD', 'w') as f:
    f.write(new_content)
" 2>/dev/null && echo -e "    ${GREEN}↳ Refreshed customer context: $cust_name${RESET}"
    fi
  fi

  # Track the first project's skills dir as source for CLAUDE.md generation
  echo "$project_dir/.claude/skills" >> /tmp/aidevkit_first_skills_dir 2>/dev/null || true
done

# Count updated projects (find | while runs in subshell, can't increment counter)
UPDATED=$(find "$DEV_DIR" -maxdepth 3 -name ".ai-dev-kit" -type d 2>/dev/null | while read d; do
  dir="$(dirname "$d")"
  [[ -f "$dir/CUSTOMER.md" ]] && continue
  echo "$dir"
done | wc -l | tr -d ' ')

FIRST_PROJECT_SKILLS_DIR=""
if [[ -f /tmp/aidevkit_first_skills_dir ]]; then
  FIRST_PROJECT_SKILLS_DIR="$(head -1 /tmp/aidevkit_first_skills_dir)"
  rm -f /tmp/aidevkit_first_skills_dir
fi

if [[ $UPDATED -eq 0 ]]; then
  warn "No AI Dev Kit projects found in ~/dev/ — CLAUDE.md will use local repo for skill names."
  FIRST_PROJECT_SKILLS_DIR="$AI_DEV_KIT_REPO/databricks-skills"
fi

ok "Skills refreshed in $UPDATED project(s)"

# ── Step 3: Rebuild ~/.claude/CLAUDE.md skill table from freshly updated skills
echo ""
log "Regenerating ~/.claude/CLAUDE.md skill table from latest skills..."

if [[ ! -d "$FIRST_PROJECT_SKILLS_DIR" ]]; then
  warn "No skills directory found — skipping CLAUDE.md regeneration."
else
  # Build skill table by reading SKILL.md frontmatter from the freshly downloaded skills
  SKILL_TABLE=""
  for skill_dir in "$FIRST_PROJECT_SKILLS_DIR"/*/; do
    skill_name="$(basename "$skill_dir")"
    [[ "$skill_name" == "TEMPLATE" ]] && continue
    skill_file="$skill_dir/SKILL.md"
    [[ ! -f "$skill_file" ]] && continue
    description="$(grep -m1 '^description:' "$skill_file" | sed 's/^description:[[:space:]]*//' | tr -d '"')"
    short_desc="$(echo "$description" | sed 's/\. .*//' | cut -c1-80)"
    SKILL_TABLE="${SKILL_TABLE}| \`${skill_name}\` | ${short_desc} |\n"
  done

  # Read user config for personalization
  CONFIG_FILE="$HOME/.config/aidevkit/config"
  if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
  fi
  user_name="${USER_NAME:-$(git config --global user.name 2>/dev/null || echo "Developer")}"
  user_role="${USER_ROLE:-Databricks Developer}"

  # Backup existing CLAUDE.md before regenerating
  if [[ -f "$GLOBAL_CLAUDE_MD" ]]; then
    cp "$GLOBAL_CLAUDE_MD" "$GLOBAL_CLAUDE_MD.bak"
  fi

  # Write the global CLAUDE.md with the freshly generated table
  cat > "$GLOBAL_CLAUDE_MD" <<HEREDOC
# Global AI Assistant Instructions

## About Me
- **Name:** $user_name
- **Role:** $user_role

---

## Databricks Skills

Every project created with \`newproject\` includes Databricks-specific skills in \`.claude/skills/\`. Always use these as the **primary reference** for Databricks tasks — prefer them over general training knowledge.

| Skill | When to use |
|-------|-------------|
$(echo -e "$SKILL_TABLE" | sed '/^$/d')

---

## MCP Tools

The Databricks MCP server is configured per-project in \`.mcp.json\`. When available, use these tools to execute work directly on Databricks rather than generating code for the user to run:

| Tool | Purpose |
|------|---------|
| \`mcp__databricks__execute_sql\` | Run SQL against a warehouse |
| \`mcp__databricks__run_python_file_on_databricks\` | Run a Python file on a cluster |
| \`mcp__databricks__upload_file\` | Upload a file to the workspace |
| \`mcp__databricks__upload_folder\` | Upload a folder to the workspace |
| \`mcp__databricks__create_or_update_pipeline\` | Create or update a DLT pipeline |
| \`mcp__databricks__start_update\` | Start a pipeline update |
| \`mcp__databricks__get_update\` | Get pipeline update status |
| \`mcp__databricks__get_pipeline\` | Get pipeline details |
| \`mcp__databricks__get_pipeline_events\` | Get pipeline events/logs |
| \`mcp__databricks__delete_pipeline\` | Delete a pipeline |
| \`mcp__databricks__execute_sql_multi\` | Run multiple SQL statements |

---

## Environment Defaults

- Use \`uv\` for Python dependency management (\`uv venv\`, \`uv pip install\`)
- Databricks CLI is available: verify auth with \`databricks auth status\`
- Default Databricks profile: \`DEFAULT\`
HEREDOC

  # Append user's custom rules if they exist (never overwritten by updates)
  CUSTOM_CLAUDE_MD="$HOME/.claude/CLAUDE-custom.md"
  if [[ -f "$CUSTOM_CLAUDE_MD" ]]; then
    echo "" >> "$GLOBAL_CLAUDE_MD"
    echo "---" >> "$GLOBAL_CLAUDE_MD"
    echo "" >> "$GLOBAL_CLAUDE_MD"
    cat "$CUSTOM_CLAUDE_MD" >> "$GLOBAL_CLAUDE_MD"
    ok "~/.claude/CLAUDE.md regenerated (with custom rules from CLAUDE-custom.md)"
  else
    ok "~/.claude/CLAUDE.md regenerated"
    log "Tip: Create ~/.claude/CLAUDE-custom.md for personal rules that survive updates"
  fi
  log "Previous CLAUDE.md backed up to ~/.claude/CLAUDE.md.bak"
fi

# ── Step 4: Sync launchpad templates → installed project templates ────────────
echo ""
log "Syncing launchpad templates to ~/.local/share/project-templates/..."

LAUNCHPAD_DIR="${LAUNCHPAD_DIR:-$DEV_DIR/launchpad}"
INSTALLED_TEMPLATES="$HOME/.local/share/project-templates"

if [[ -d "$LAUNCHPAD_DIR/templates" ]]; then
  SYNCED=0
  for subdir in commands agents; do
    src="$LAUNCHPAD_DIR/templates/$subdir"
    dst="$INSTALLED_TEMPLATES/$subdir"
    if [[ -d "$src" ]]; then
      mkdir -p "$dst"
      for f in "$src"/*.md; do
        [[ -f "$f" ]] || continue
        fname="$(basename "$f")"
        if ! diff -q "$f" "$dst/$fname" &>/dev/null; then
          cp "$f" "$dst/$fname"
          echo -e "  ${CYAN}→${RESET} $subdir/$fname"
          SYNCED=$((SYNCED + 1))
        fi
      done
    fi
  done
  if [[ $SYNCED -eq 0 ]]; then
    ok "Launchpad templates already in sync"
  else
    ok "Synced $SYNCED template file(s) from launchpad"
  fi
else
  warn "Launchpad not found at $LAUNCHPAD_DIR — skipping template sync"
  log "Set LAUNCHPAD_DIR in $HOME/.config/aidevkit/config to fix"
fi

# ── Done ──────────────────────────────────────────────────────────────────────
echo ""
echo -e "${GREEN}${BOLD}Update complete!${RESET}"
echo -e "  AI Dev Kit:   ${CYAN}v${INSTALLED_VERSION}${RESET}"
echo -e "  CLAUDE.md:    ${CYAN}~/.claude/CLAUDE.md${RESET} regenerated"
echo -e "  Projects:     ${CYAN}${UPDATED} updated${RESET}"
echo -e "  Templates:    ${CYAN}~/.local/share/project-templates${RESET} synced from launchpad"
echo ""
