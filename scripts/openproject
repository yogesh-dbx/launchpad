#!/usr/bin/env bash
# openproject - Open an existing project with Claude Code
set -euo pipefail

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

die() { echo -e "${RED}✗${RESET} $*" >&2; exit 1; }

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
  echo -e "${BOLD}Usage:${RESET}  openproject [project-name | /full/path]"
  echo ""
  echo "  With no arguments:  interactive picker from ~/dev"
  echo "  With a name:        opens ~/dev/<name>"
  echo "  With a path:        opens that directory"
  echo ""
  echo -e "${BOLD}Examples:${RESET}"
  echo "  openproject                  # interactive picker"
  echo "  openproject my-pipeline      # opens ~/dev/my-pipeline"
  echo "  openproject /tmp/scratch     # opens /tmp/scratch"
  exit 1
}

[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && usage

# ── Resolve dev directory ─────────────────────────────────────────────────────
CONFIG_FILE="$HOME/.config/aidevkit/config"
if [[ -f "$CONFIG_FILE" ]]; then
  source "$CONFIG_FILE"
fi
DEV_DIR="${DEV_DIR:-$HOME/dev}"

# ── Detect terminal + Claude ──────────────────────────────────────────────────
if ! command -v claude &>/dev/null; then
  die "'claude' CLI not found. Install: npm install -g @anthropic-ai/claude-code"
fi
CLAUDE_BIN="$(command -v claude)"

GHOSTTY_BIN=""
HAS_GHOSTTY=false
if command -v ghostty &>/dev/null; then
  GHOSTTY_BIN="$(command -v ghostty)"
  HAS_GHOSTTY=true
elif [[ -x "/Applications/Ghostty.app/Contents/MacOS/ghostty" ]]; then
  GHOSTTY_BIN="/Applications/Ghostty.app/Contents/MacOS/ghostty"
  HAS_GHOSTTY=true
fi

# ── Launch helper ─────────────────────────────────────────────────────────────
launch() {
  local dir="$1"
  local name
  name="$(basename "$dir")"

  if [[ "${TERM_PROGRAM:-}" == "vscode" ]]; then
    echo -e "  Run: ${CYAN}cd $dir && claude${RESET}"
  elif [[ "$HAS_GHOSTTY" == true ]]; then
    "$GHOSTTY_BIN" \
      --working-directory="$dir" \
      --command="$CLAUDE_BIN" \
      &
    echo -e "${GREEN}✓${RESET} Opening ${CYAN}$name${RESET} in Ghostty..."
  else
    echo -e "${GREEN}✓${RESET} Opening ${CYAN}$name${RESET}..."
    cd "$dir" && exec "$CLAUDE_BIN"
  fi
}

# ── Direct open (argument given) ──────────────────────────────────────────────
if [[ -n "${1:-}" ]]; then
  if [[ "$1" == /* ]]; then
    dir="$1"
  else
    dir="$DEV_DIR/$1"
  fi

  [[ -d "$dir" ]] || die "Directory not found: $dir"
  launch "$dir"
  exit 0
fi

# ── Interactive picker (no argument) ──────────────────────────────────────────
[[ -d "$DEV_DIR" ]] || die "Projects directory not found: $DEV_DIR"
projects=()
while IFS= read -r d; do
  projects+=("$DEV_DIR/$d")
done < <(ls -t "$DEV_DIR" | while read -r name; do [[ -d "$DEV_DIR/$name" && "$name" != .* ]] && echo "$name"; done)

if [[ ${#projects[@]} -eq 0 ]]; then
  die "No projects in $DEV_DIR"
fi

echo ""
echo -e "  ${BOLD}Projects in $DEV_DIR:${RESET}"
echo "  ───────────────────"
i=1
for p in "${projects[@]}"; do
  printf "  %2d)  %s\n" "$i" "$(basename "$p")"
  (( i++ ))
done
echo ""
printf "  Select (1-%d): " "${#projects[@]}"
read -r choice

if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#projects[@]} )); then
  die "Invalid selection."
fi

selected="${projects[$((choice - 1))]}"
launch "$selected"
