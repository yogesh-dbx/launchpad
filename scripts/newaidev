#!/usr/bin/env bash
set -euo pipefail

INSTALLER_URL="${AIDEVKIT_INSTALLER_URL:-https://raw.githubusercontent.com/databricks-solutions/ai-dev-kit/main/install.sh}"
DEFAULT_PROFILE="${DATABRICKS_CONFIG_PROFILE:-DEFAULT}"
DEFAULT_TOOLS="${AIDEVKIT_TOOLS:-claude,codex}"
DEFAULT_SILENT="${AIDEVKIT_SILENT:-true}"

usage() {
  cat <<USAGE
Usage: newaidev <project-path> [--no-install] [--profile NAME] [--tools LIST] [--silent true|false]

Creates a new empty project, then runs the ai-dev-kit installer to add
Databricks skills, MCP server config, and plugin setup.

Options:
  --no-install        Only create project directory, skip ai-dev-kit installer
  --profile NAME      Databricks profile for installer (default: ${DEFAULT_PROFILE})
  --tools LIST        Comma-separated tools (default: ${DEFAULT_TOOLS})
                      Options: claude, codex, cursor, copilot, gemini
  --silent true|false Installer silent mode (default: ${DEFAULT_SILENT})
  -h, --help          Show this help

Environment overrides:
  AIDEVKIT_INSTALLER_URL  Installer script URL
  AIDEVKIT_TOOLS          Default tools list
  AIDEVKIT_SILENT         Default installer silent mode
USAGE
}

if [[ "${1:-}" =~ ^(-h|--help)$ ]]; then
  usage
  exit 0
fi

TARGET="${1:-}"
if [[ -z "$TARGET" ]]; then
  usage >&2
  exit 1
fi
shift

RUN_INSTALL=true
PROFILE="$DEFAULT_PROFILE"
TOOLS="$DEFAULT_TOOLS"
SILENT="$DEFAULT_SILENT"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-install)
      RUN_INSTALL=false
      shift
      ;;
    --profile)
      PROFILE="${2:-}"
      [[ -n "$PROFILE" ]] || { echo "Error: --profile requires a value" >&2; exit 1; }
      shift 2
      ;;
    --tools)
      TOOLS="${2:-}"
      [[ -n "$TOOLS" ]] || { echo "Error: --tools requires a value" >&2; exit 1; }
      shift 2
      ;;
    --silent)
      SILENT="${2:-}"
      [[ "$SILENT" == "true" || "$SILENT" == "false" ]] || { echo "Error: --silent must be true|false" >&2; exit 1; }
      shift 2
      ;;
    *)
      echo "Error: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

# Create empty project with git init
"$HOME/.local/bin/newproj" "$TARGET"

# Run the ai-dev-kit installer (downloads skills, MCP config, plugin setup)
if [[ "$RUN_INSTALL" == true ]]; then
  echo "Running ai-dev-kit installer in $TARGET ..."
  (
    cd "$TARGET"
    DEVKIT_PROFILE="$PROFILE" \
    DEVKIT_TOOLS="$TOOLS" \
    DEVKIT_SCOPE="project" \
    DEVKIT_SILENT="$SILENT" \
    DEVKIT_FORCE=true \
    bash <(curl -sL "$INSTALLER_URL") --silent
  )
fi

echo "Ready: $TARGET"
