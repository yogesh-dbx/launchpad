#!/usr/bin/env bash
# newproject - Create a new project, install AI Dev Kit, and launch Claude Code
set -euo pipefail

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log()    { echo -e "${CYAN}▶${RESET} $*"; }
ok()     { echo -e "${GREEN}✓${RESET} $*"; }
warn()   { echo -e "${YELLOW}⚠${RESET}  $*"; }
die()    { echo -e "${RED}✗${RESET} $*" >&2; exit 1; }

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
  echo -e "${BOLD}Usage:${RESET}  newproject <project-name> [options]"
  echo ""
  echo -e "${BOLD}Options:${RESET}"
  echo "  --profile <name>    Databricks CLI profile (default: DEFAULT)"
  echo "  --catalog <name>    Unity Catalog name (prompted if omitted)"
  echo "  --no-github         Skip GitHub repo + Projects v2 setup"
  echo "  --public            Make the GitHub repo public (default: private)"
  echo "  --no-open           Don't launch Claude Code after setup"
  echo ""
  echo -e "${BOLD}Examples:${RESET}"
  echo "  newproject my-pipeline --profile my-workspace --catalog analytics"
  echo "  newproject quick-test --no-github --no-open"
  echo "  newproject demo-app --catalog analytics --public"
  echo ""
  echo "Creates ~/dev/<project-name>, installs the Databricks AI Dev Kit,"
  echo "stamps project config with your profile and catalog, then opens Claude Code."
  exit 1
}

# ── Parse arguments ───────────────────────────────────────────────────────────
[[ $# -lt 1 ]] && usage
[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && usage

PROJECT_NAME="$1"
shift

PROFILE=""
CATALOG=""
DO_GITHUB=true
GH_PUBLIC=""
OPEN_AFTER=true

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)    PROFILE="$2"; shift 2 ;;
    --catalog)    CATALOG="$2"; shift 2 ;;
    --no-github)  DO_GITHUB=false; shift ;;
    --public)     GH_PUBLIC="--public"; shift ;;
    --no-open)    OPEN_AFTER=false; shift ;;
    *) die "Unknown option: $1. Run 'newproject --help' for usage." ;;
  esac
done

# ── Validate project name ────────────────────────────────────────────────────
if [[ -z "$PROJECT_NAME" ]]; then
  die "Project name cannot be empty."
fi
if [[ "$PROJECT_NAME" =~ [/\\] ]]; then
  die "Project name cannot contain slashes."
fi
if [[ "$PROJECT_NAME" =~ ^[[:space:]] || "$PROJECT_NAME" =~ [[:space:]]$ ]]; then
  die "Project name cannot start or end with spaces. Use hyphens instead."
fi

# ── Resolve profile ──────────────────────────────────────────────────────────
if [[ -z "$PROFILE" ]]; then
  PROFILE="${DATABRICKS_CONFIG_PROFILE:-DEFAULT}"
fi
export DATABRICKS_CONFIG_PROFILE="$PROFILE"

# ── Resolve paths ─────────────────────────────────────────────────────────────
# Read DEV_DIR from config if available, otherwise default to ~/dev
CONFIG_FILE="$HOME/.config/aidevkit/config"
if [[ -f "$CONFIG_FILE" ]]; then
  source "$CONFIG_FILE"
fi
DEV_DIR="${DEV_DIR:-$HOME/dev}"
PROJECT_DIR="$DEV_DIR/$PROJECT_NAME"

if [[ -e "$PROJECT_DIR" ]]; then
  die "Directory already exists: $PROJECT_DIR"
fi

# ── Check prerequisites ──────────────────────────────────────────────────────
if ! command -v claude &>/dev/null; then
  die "'claude' CLI not found in PATH. Install Claude Code first:\n  npm install -g @anthropic-ai/claude-code"
fi
CLAUDE_BIN="$(command -v claude)"

# Detect terminal for launch
GHOSTTY_BIN=""
HAS_GHOSTTY=false
if command -v ghostty &>/dev/null; then
  GHOSTTY_BIN="$(command -v ghostty)"
  HAS_GHOSTTY=true
elif [[ -x "/Applications/Ghostty.app/Contents/MacOS/ghostty" ]]; then
  GHOSTTY_BIN="/Applications/Ghostty.app/Contents/MacOS/ghostty"
  HAS_GHOSTTY=true
fi

# ── Verify Databricks auth ───────────────────────────────────────────────────
echo ""
echo -e "${BOLD}newproject${RESET} — setting up ${CYAN}$PROJECT_NAME${RESET}"
echo "──────────────────────────────────────────────"
log "Checking Databricks auth for profile: $PROFILE"

if databricks auth status --profile "$PROFILE" &>/dev/null; then
  ok "Authenticated with profile '$PROFILE'"
else
  warn "Profile '$PROFILE' not authenticated. Running login..."
  databricks auth login --profile "$PROFILE" || die "Authentication failed for profile '$PROFILE'"
  ok "Authenticated with profile '$PROFILE'"
fi

# ── Resolve catalog ──────────────────────────────────────────────────────────
if [[ -z "$CATALOG" ]]; then
  # Try to read from profile config
  DBX_CATALOG=$(awk -v p="[$PROFILE]" '
    $0 == p { found=1; next }
    found && /^\[/ { exit }
    found && /^catalog/ { gsub(/^catalog[ ]*=[ ]*/, ""); print; exit }
  ' "$HOME/.databrickscfg" 2>/dev/null) || true

  if [[ -n "$DBX_CATALOG" ]]; then
    CATALOG="$DBX_CATALOG"
    ok "Catalog from profile: $CATALOG"
  else
    echo -e -n "  ${CYAN}Enter Unity Catalog name for this project:${RESET} "
    read -r CATALOG
    [[ -z "$CATALOG" ]] && die "Catalog name is required. Use --catalog <name> or set it in your profile."
  fi
fi
ok "Unity Catalog: $CATALOG"

# ── Create project directory ─────────────────────────────────────────────────
log "Creating $PROJECT_DIR"
mkdir -p "$PROJECT_DIR"
ok "Directory created"

# ── Run AI Dev Kit installer ─────────────────────────────────────────────────
echo ""
log "Running Databricks AI Dev Kit installer..."
echo -e "  ${YELLOW}(Running silently with profile: $PROFILE)${RESET}"
echo ""

(
  cd "$PROJECT_DIR"
  DEVKIT_PROFILE="$PROFILE" \
  DEVKIT_SCOPE=project \
  DEVKIT_TOOLS=claude,cursor,copilot \
  DEVKIT_MCP_PATH="$HOME/.ai-dev-kit" \
  DEVKIT_SILENT=true \
    bash <(curl -sL https://raw.githubusercontent.com/databricks-solutions/ai-dev-kit/main/install.sh)
) || {
  warn "AI Dev Kit installer exited with errors. The project directory has been kept."
  warn "Re-run manually: cd $PROJECT_DIR && bash <(curl -sL https://raw.githubusercontent.com/databricks-solutions/ai-dev-kit/main/install.sh)"
}

# ── GitHub initialization (or local-only template copy) ──────────────────────
TEMPLATES_DIR="$HOME/.local/share/project-templates"

if [[ "$DO_GITHUB" == true ]]; then
  if command -v gh-project-init &>/dev/null; then
    echo ""
    log "Running GitHub project initialization..."
    local_args=("$PROJECT_DIR" --yes --catalog "$CATALOG")
    [[ -n "$GH_PUBLIC" ]] && local_args+=("$GH_PUBLIC")

    if gh-project-init "${local_args[@]}"; then
      ok "GitHub repo + Projects v2 initialized"
    else
      warn "GitHub init failed (project still usable locally)"
    fi
  else
    warn "gh-project-init not found in PATH. Skipping GitHub setup."
    warn "Install it from the launchpad repo: cp scripts/gh-project-init ~/.local/bin/"
    DO_GITHUB=false
  fi
fi

if [[ "$DO_GITHUB" == false && -d "$TEMPLATES_DIR" ]]; then
  # Copy templates locally without GitHub
  log "Copying project templates (local-only mode)..."
  mkdir -p "$PROJECT_DIR/.claude/commands" "$PROJECT_DIR/.claude/agents"

  cp "$TEMPLATES_DIR/commands/"*.md "$PROJECT_DIR/.claude/commands/" 2>/dev/null || true
  cp "$TEMPLATES_DIR/agents/"*.md "$PROJECT_DIR/.claude/agents/" 2>/dev/null || true

  # Copy and stamp project CLAUDE.md
  if [[ -f "$TEMPLATES_DIR/CLAUDE.md" ]]; then
    cp "$TEMPLATES_DIR/CLAUDE.md" "$PROJECT_DIR/.claude/CLAUDE.md"
    # Stamp placeholders
    if [[ "$(uname)" == "Darwin" ]]; then
      sed -i '' "s/PROJECT_NAME/$PROJECT_NAME/g" "$PROJECT_DIR/.claude/CLAUDE.md"
      sed -i '' "s/PROJECT_CATALOG/$CATALOG/g" "$PROJECT_DIR/.claude/CLAUDE.md"
      sed -i '' "s/DATABRICKS_PROFILE/$PROFILE/g" "$PROJECT_DIR/.claude/CLAUDE.md"
    else
      sed -i "s/PROJECT_NAME/$PROJECT_NAME/g" "$PROJECT_DIR/.claude/CLAUDE.md"
      sed -i "s/PROJECT_CATALOG/$CATALOG/g" "$PROJECT_DIR/.claude/CLAUDE.md"
      sed -i "s/DATABRICKS_PROFILE/$PROFILE/g" "$PROJECT_DIR/.claude/CLAUDE.md"
    fi
    ok ".claude/CLAUDE.md stamped (project: $PROJECT_NAME, catalog: $CATALOG)"
  fi

  # Copy and stamp databricks.yml
  if [[ -f "$TEMPLATES_DIR/databricks/databricks.yml" ]]; then
    mkdir -p "$PROJECT_DIR"
    cp "$TEMPLATES_DIR/databricks/databricks.yml" "$PROJECT_DIR/databricks.yml"
    if [[ "$(uname)" == "Darwin" ]]; then
      sed -i '' "s/PROJECT_NAME/$PROJECT_NAME/g" "$PROJECT_DIR/databricks.yml"
      sed -i '' "s/PROJECT_CATALOG/$CATALOG/g" "$PROJECT_DIR/databricks.yml"
      sed -i '' "s/DATABRICKS_PROFILE/$PROFILE/g" "$PROJECT_DIR/databricks.yml"
    else
      sed -i "s/PROJECT_NAME/$PROJECT_NAME/g" "$PROJECT_DIR/databricks.yml"
      sed -i "s/PROJECT_CATALOG/$CATALOG/g" "$PROJECT_DIR/databricks.yml"
      sed -i "s/DATABRICKS_PROFILE/$PROFILE/g" "$PROJECT_DIR/databricks.yml"
    fi
    ok "databricks.yml stamped"
  fi

  # Copy setup script
  if [[ -f "$TEMPLATES_DIR/scripts/01_setup_infrastructure.py" ]]; then
    mkdir -p "$PROJECT_DIR/scripts"
    cp "$TEMPLATES_DIR/scripts/01_setup_infrastructure.py" "$PROJECT_DIR/scripts/"
    if [[ "$(uname)" == "Darwin" ]]; then
      sed -i '' "s/PROJECT_CATALOG/$CATALOG/g" "$PROJECT_DIR/scripts/01_setup_infrastructure.py"
    else
      sed -i "s/PROJECT_CATALOG/$CATALOG/g" "$PROJECT_DIR/scripts/01_setup_infrastructure.py"
    fi
    ok "scripts/01_setup_infrastructure.py stamped"
  fi

  ok "Templates copied (local-only mode)"
fi

# ── Create .claude/settings.local.json if missing ────────────────────────────
CLAUDE_SETTINGS="$PROJECT_DIR/.claude/settings.local.json"
if [[ ! -f "$CLAUDE_SETTINGS" ]]; then
  log "Creating .claude/settings.local.json with safety permissions..."
  mkdir -p "$PROJECT_DIR/.claude"
  cat > "$CLAUDE_SETTINGS" <<'EOF'
{
  "permissions": {
    "allow": [
      "Bash(env)",
      "Bash(find:*)",
      "mcp__databricks__run_python_file_on_databricks",
      "mcp__databricks__execute_sql",
      "mcp__databricks__upload_file",
      "mcp__databricks__create_or_update_pipeline",
      "Bash(databricks auth:*)",
      "mcp__databricks__start_update",
      "mcp__databricks__get_update",
      "mcp__databricks__get_pipeline_events",
      "mcp__databricks__get_pipeline",
      "Bash(databricks workspace export:*)",
      "Bash(databricks workspace ls:*)",
      "Bash(databricks workspace list:*)",
      "mcp__databricks__delete_pipeline",
      "Bash(databricks workspace delete:*)",
      "mcp__databricks__upload_folder",
      "mcp__databricks__execute_sql_multi",
      "Bash(ls:*)",
      "WebFetch(domain:github.com)",
      "Bash(xargs:*)",
      "Bash(git fetch:*)",
      "Bash(git clone:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(chmod -R 777*)"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(npm publish*)",
      "Bash(docker *)",
      "Bash(kubectl delete*)"
    ]
  },
  "plansDirectory": ".claude/plans",
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "databricks"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-todo-hook"
          }
        ]
      }
    ]
  }
}
EOF
  ok ".claude/settings.local.json created"
else
  ok ".claude/settings.local.json already exists, skipping"
fi

# ── Create top-level CLAUDE.md if missing (fallback) ─────────────────────────
CLAUDE_MD="$PROJECT_DIR/CLAUDE.md"
if [[ ! -f "$CLAUDE_MD" && ! -f "$PROJECT_DIR/.claude/CLAUDE.md" ]]; then
  log "Creating CLAUDE.md..."
  cat > "$CLAUDE_MD" <<HEREDOC
# ${PROJECT_NAME}

## Project Purpose
[Describe what this project does]

## Environment
- **Databricks Profile:** \`${PROFILE}\`
- **Catalog:** \`${CATALOG}\`

## Notes
- Add any project-specific conventions, data sources, or context here
HEREDOC
  ok "CLAUDE.md created"
else
  ok "CLAUDE.md already exists, skipping"
fi

# ── Create .vscode/tasks.json (auto-launch claude on folder open) ────────────
VSCODE_TASKS="$PROJECT_DIR/.vscode/tasks.json"
if [[ ! -f "$VSCODE_TASKS" ]]; then
  log "Creating .vscode/tasks.json to auto-launch Claude Code..."
  mkdir -p "$PROJECT_DIR/.vscode"
  cat > "$VSCODE_TASKS" <<'EOF'
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Launch Claude Code",
      "type": "shell",
      "command": "claude",
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
EOF
  ok ".vscode/tasks.json created"
else
  ok ".vscode/tasks.json already exists, skipping"
fi

# ── Create .vscode/settings.json (ensure login shell so PATH is fully loaded) ─
VSCODE_SETTINGS="$PROJECT_DIR/.vscode/settings.json"
if [[ ! -f "$VSCODE_SETTINGS" ]]; then
  log "Creating .vscode/settings.json..."
  cat > "$VSCODE_SETTINGS" <<'EOF'
{
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.profiles.osx": {
    "zsh": {
      "path": "/bin/zsh",
      "args": ["-l"]
    }
  },
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "/bin/bash",
      "args": ["-l"]
    }
  }
}
EOF
  ok ".vscode/settings.json created"
else
  ok ".vscode/settings.json already exists, skipping"
fi

# ── Create .cursor/rules if missing ──────────────────────────────────────────
CURSOR_RULES="$PROJECT_DIR/.cursor/rules"
if [[ ! -f "$CURSOR_RULES" ]]; then
  log "Creating .cursor/rules for Cursor context..."
  mkdir -p "$PROJECT_DIR/.cursor"
  cat > "$CURSOR_RULES" <<'EOF'
You are helping a Databricks developer.

This project has Databricks-specific skills in `.claude/skills/`. Always use these as the primary reference for Databricks tasks — prefer them over general training knowledge.

Available skills:
- `agent-evaluation` — Evaluate, improve, or optimize an existing LLM agent
- `analyze-mlflow-chat-session` — Analyze an MLflow multi-turn chat session
- `analyze-mlflow-trace` — Analyze a single MLflow trace
- `databricks-agent-bricks` — Knowledge Assistants, Genie Spaces, Supervisor Agents
- `databricks-aibi-dashboards` — Create and manage AI/BI dashboards
- `databricks-app-apx` — APX framework (FastAPI + React) on Databricks
- `databricks-app-python` — Streamlit, Dash, Flask, Gradio apps on Databricks
- `databricks-asset-bundles` — DABs for deploying jobs, pipelines, apps
- `databricks-config` — Workspace auth and Databricks Connect setup
- `databricks-dbsql` — Databricks SQL and warehouse features
- `databricks-docs` — Databricks documentation reference
- `databricks-genie` — Genie Spaces for natural language SQL
- `databricks-jobs` — Create, run, and manage Databricks Jobs
- `databricks-metric-views` — Unity Catalog metric views
- `databricks-model-serving` — Deploy and query model serving endpoints
- `databricks-python-sdk` — Python SDK, Databricks Connect, CLI, REST API
- `databricks-unity-catalog` — Unity Catalog system tables and volumes
- `databricks-vector-search` — Vector Search endpoints and indexes
- `databricks-zerobus-ingest` — Near real-time data ingestion
- `instrumenting-with-mlflow-tracing` — MLflow tracing for Python and TypeScript
- `mlflow-onboarding` — Getting started with MLflow
- `querying-mlflow-metrics` — Fetch aggregated trace metrics
- `retrieving-mlflow-traces` — Retrieve MLflow traces via CLI or Python
- `searching-mlflow-docs` — Search MLflow documentation
- `spark-python-data-source` — Custom Spark data source connectors

## MCP Tools (Databricks MCP server configured in .cursor/mcp.json)
- `databricks_execute_sql` — Run SQL against a warehouse
- `databricks_run_python_file_on_databricks` — Run Python on a cluster
- `databricks_upload_file` / `upload_folder` — Upload to workspace
- `databricks_create_or_update_pipeline` / `start_update` / `get_update` — Manage DLT pipelines
- `databricks_execute_sql_multi` — Run multiple SQL statements

## Environment
- Use `uv` for Python deps (`uv venv`, `uv pip install`)
- Databricks CLI available: check auth with `databricks auth status`
- Default profile: `DEFAULT`
EOF
  ok ".cursor/rules created"
else
  ok ".cursor/rules already exists, skipping"
fi

# ── Summary ───────────────────────────────────────────────────────────────────
echo ""
echo "──────────────────────────────────────────────"
echo -e "${GREEN}${BOLD}Project ready!${RESET}"
echo ""
echo -e "  Name:     ${CYAN}$PROJECT_NAME${RESET}"
echo -e "  Path:     ${CYAN}$PROJECT_DIR${RESET}"
echo -e "  Profile:  ${CYAN}$PROFILE${RESET}"
echo -e "  Catalog:  ${CYAN}$CATALOG${RESET}"
echo -e "  GitHub:   ${CYAN}$( [[ "$DO_GITHUB" == true ]] && echo "yes" || echo "no" )${RESET}"
echo ""

# ── Launch ────────────────────────────────────────────────────────────────────
if [[ "$OPEN_AFTER" == false ]]; then
  echo -e "To start working:"
  echo -e "  ${CYAN}cd $PROJECT_DIR && claude${RESET}"
elif [[ "${TERM_PROGRAM:-}" == "vscode" ]]; then
  echo -e "Run this to open it:"
  echo -e "  ${CYAN}cd $PROJECT_DIR && claude${RESET}"
  echo ""
  echo -e "  Or open in VS Code: ${CYAN}code $PROJECT_DIR${RESET}"
  echo -e "  Or open in Cursor:  ${CYAN}cursor $PROJECT_DIR${RESET}"
elif [[ "$HAS_GHOSTTY" == true ]]; then
  log "Launching Ghostty with Claude Code..."
  "$GHOSTTY_BIN" \
    --working-directory="$PROJECT_DIR" \
    --command="$CLAUDE_BIN" \
    &
  ok "Ghostty launched!"
else
  echo -e "To start working:"
  echo -e "  ${CYAN}cd $PROJECT_DIR && claude${RESET}"
fi
echo ""
