#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<USAGE
Usage: newproj <project-path>

Creates a new empty project directory with a fresh git repo.
Run the ai-dev-kit installer separately to add skills and MCP config.

Options:
  -h, --help    Show this help
USAGE
}

if [[ "${1:-}" =~ ^(-h|--help)$ ]]; then
  usage
  exit 0
fi

TARGET="${1:-}"
if [[ -z "$TARGET" ]]; then
  usage >&2
  exit 1
fi

if [[ -e "$TARGET" ]]; then
  echo "Error: target path already exists: $TARGET" >&2
  exit 1
fi

mkdir -p "$TARGET"
git -C "$TARGET" init -q

echo "Created project at: $TARGET"
