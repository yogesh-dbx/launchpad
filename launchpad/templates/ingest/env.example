# Zerobus Ingest Configuration
# Copy to .env and fill in values. NEVER commit .env to git.

# Zerobus gRPC endpoint: <workspace-id>.zerobus.<region>.cloud.databricks.com
ZEROBUS_SERVER_ENDPOINT=INGEST_WORKSPACE_ID.zerobus.INGEST_REGION.cloud.databricks.com

# Databricks workspace URL
DATABRICKS_WORKSPACE_URL=INGEST_WORKSPACE_URL

# Service principal OAuth credentials (generate from Account Console)
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# Target table (default: INGEST_TABLE_NAME)
ZEROBUS_TABLE_NAME=INGEST_TABLE_NAME
